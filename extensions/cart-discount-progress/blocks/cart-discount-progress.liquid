{% liquid
  assign endpoint = routes.root_url | append: 'apps/discount-progress/widget-data'
%}

{{ 'cart-discount-widget.css' | asset_url | stylesheet_tag }}

<div
  class="cdp-widget"
  data-cdp-widget
  data-endpoint="{{ endpoint }}"
  data-tiers="{{ block.settings.bulk_tiers | escape }}"
  data-max-recommendations="{{ block.settings.max_recommendations }}"
  data-near-threshold-percent="{{ block.settings.near_threshold_percent }}"
  data-recommendations-enabled="{{ block.settings.enable_recommendations }}"
  data-tracking-enabled="{{ block.settings.enable_tracking }}"
  data-xyz-hint-enabled="{{ block.settings.enable_xyz_hint }}"
  data-xyz-hint-message="{{ block.settings.xyz_hint_message | escape }}"
></div>
<noscript>
  <div class="cdp-widget">
    <div class="cdp-card">
      <p class="cdp-primary">Enable JavaScript to view discount progress.</p>
    </div>
  </div>
</noscript>

<script src="{{ 'cart-discount-widget.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Cart Discount Progress",
  "target": "section",
  "templates": ["cart"],
  "settings": [
    {
      "type": "text",
      "id": "bulk_tiers",
      "label": "Bulk tiers",
      "default": "100:5,250:10,400:13,600:15",
      "info": "Format: amount:percent or code:amount:percent"
    },
    {
      "type": "range",
      "id": "max_recommendations",
      "label": "Max recommendations",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "near_threshold_percent",
      "label": "Near threshold percent",
      "min": 5,
      "max": 40,
      "step": 1,
      "default": 20
    },
    {
      "type": "checkbox",
      "id": "enable_recommendations",
      "label": "Enable recommendations",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_xyz_hint",
      "label": "Enable X/Y/Z hint message",
      "default": false
    },
    {
      "type": "text",
      "id": "xyz_hint_message",
      "label": "X/Y/Z hint message",
      "default": "Add qualifying collection items to improve your total discount."
    },
    {
      "type": "checkbox",
      "id": "enable_tracking",
      "label": "Enable console tracking",
      "default": true
    }
  ]
}
{% endschema %}
