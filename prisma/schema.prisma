// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model HvacSkuMapping {
  id                  Int      @id @default(autoincrement())
  shop                String
  sourceSku           String
  sourceType          String?  // indoor|outdoor|unknown
  sourceBrand         String?
  sourceSeries        String?
  sourceSystem        String?
  sourceBtu           Int?
  sourceRefrigerant   String?
  mappedVariantId     String?
  mappedVariantSku    String?
  mappedProductId     String?
  mappedProductTitle  String?
  mappedProductHandle String?
  mappedProductUrl    String?
  matchStatus         String   @default("unmapped") // unmapped|auto_exact|manual|not_found|error
  note                String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([shop, sourceSku])
  @@index([shop, matchStatus])
}

model AutoTagJob {
  id                    String   @id @default(cuid())
  shop                  String
  discountNodeId        String
  status                String   @default("running") // running|completed|failed|cancelled
  mode                  String   // tag|untag_discount
  targetTag             String?
  scheduledUndoAt       String?
  inputSkusJson         String   // JSON string array
  matchedProductsJson   String   // JSON [{id,title,tags[]},...]
  changesJson           String   @default("[]")
  errorsJson            String   @default("[]")
  cursor                Int      @default(0)
  processedCount        Int      @default(0)
  totalCount            Int      @default(0)
  changedCount          Int      @default(0)
  skippedProtectedCount Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([shop, discountNodeId, status])
  @@index([shop, createdAt])
}
