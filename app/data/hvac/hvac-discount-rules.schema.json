{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://discount-engine.local/schemas/hvac-discount-rules.schema.json",
  "title": "HVAC Discount Rules",
  "type": "object",
  "required": [
    "version",
    "rules"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ruleId",
          "name",
          "enabled",
          "stackMode",
          "when",
          "discount"
        ],
        "properties": {
          "ruleId": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "enabled": {
            "type": "boolean"
          },
          "stackMode": {
            "type": "string",
            "enum": [
              "stackable",
              "exclusive_group",
              "exclusive_global"
            ]
          },
          "stackGroup": {
            "type": "string"
          },
          "when": {
            "type": "object",
            "properties": {
              "brands": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "tiers": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "refrigerants": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "zoneMin": {
                "type": "integer",
                "minimum": 1
              },
              "zoneMax": {
                "type": "integer",
                "minimum": 1
              },
              "minBundles": {
                "type": "integer",
                "minimum": 1
              }
            },
            "additionalProperties": false
          },
          "discount": {
            "type": "object",
            "required": [
              "mode"
            ],
            "properties": {
              "mode": {
                "type": "string",
                "enum": [
                  "percent_off",
                  "fixed_amount_off_component",
                  "combined"
                ]
              },
              "percentOff": {
                "type": "number",
                "minimum": 0
              },
              "amountOff": {
                "type": "number",
                "minimum": 0
              },
              "amountTarget": {
                "type": "string",
                "enum": [
                  "outdoor",
                  "indoor_highest_price",
                  "outdoor_or_indoor_highest"
                ]
              },
              "maxApplicationsPerCart": {
                "type": "integer",
                "minimum": 1
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
